# Параметры подключения к PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=cup_it

# Секретный ключ для подписи JWT-токенов
# ВАЖНО: в продакшн использовать длинный случайный ключ (минимум 32 символа)
JWT_SECRET=change-me-in-production-use-strong-secret

# Порт HTTP-сервера
SERVER_PORT=8080

# Режим Gin: debug | release
GIN_MODE=debug
