# Переменные окружения для docker-compose
# Скопируйте этот файл в .env и заполните значения

# PostgreSQL
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=cup_it

# JWT Secret (обязательно смените в продакшн!)
JWT_SECRET=change-me-in-production-use-strong-secret-min-32-chars

# Режим Gin
GIN_MODE=release
